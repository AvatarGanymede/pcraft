# pcraft environment configuration (example)
#
# Copy this file to your pcraft home directory as `.env`:
#
#   Windows : %USERPROFILE%\.pcraft\.env      (e.g. C:\Users\<you>\.pcraft\.env)
#   macOS   : ~/.pcraft/.env
#   Linux   : ~/.pcraft/.env
#
# The backend reads it on startup. If PCRAFT_HOME_DIR is set, the file is read
# from <PCRAFT_HOME_DIR>/.env instead. Real environment variables (already set
# in your shell) always take precedence over values in this file.
#
# Lines starting with `#` are comments. Values may be quoted. Restart the
# backend after changing this file for the changes to take effect.

# ----------------------------------------------------------------------------
# JNPM (ticket assignee lookup)
# ----------------------------------------------------------------------------
# When a task carries a JNPM id (the optional "JNPM ID" field on the New Task
# dialog), the notification is routed to that ticket's assignee via Lark. Leave
# PCRAFT_JNPM_TOKEN empty to disable assignee lookup (all notifications then go
# to PCRAFT_NOTIFY_ADMIN_EMAIL).

# JNPM Open API base URL. Optional; defaults to the value below.
PCRAFT_JNPM_BASE_URL=https://jn-p-api.bytedance.net/jnpm/

# JNPM private token, sent as the `PRIVATE-TOKEN` header. Required to enable
# assignee resolution.
PCRAFT_JNPM_TOKEN=

# ----------------------------------------------------------------------------
# Lark / Feishu bot (notification delivery)
# ----------------------------------------------------------------------------
# The bot delivers notifications as direct messages addressed by email. Both
# app id and secret must be set to enable Lark delivery; otherwise Lark is
# skipped entirely.

# Feishu open-platform base domain. Optional; use https://open.larksuite.com
# for the international (Lark) tenant.
PCRAFT_LARK_BASE_DOMAIN=https://open.feishu.cn

# Custom app credentials from the Feishu open platform. The app needs the bot
# capability and the "send messages" (im:message) permission, and the target
# recipients must be within the app's availability scope.
PCRAFT_LARK_APP_ID=
PCRAFT_LARK_APP_SECRET=

# ----------------------------------------------------------------------------
# Notification fallback
# ----------------------------------------------------------------------------
# Fallback Lark recipient (email) used when a task has no JNPM id, or when the
# JNPM assignee has no email / cannot be resolved. Strongly recommended.
PCRAFT_NOTIFY_ADMIN_EMAIL=

# Externally reachable pcraft origin used to build the task deep-link appended
# to Lark messages, e.g. http://10.0.0.5:38429. Optional: when unset, the
# backend derives it from the host's outbound IP + server port (never
# localhost). Set this explicitly when clients reach pcraft through a specific
# hostname, reverse proxy, or public domain.
# PCRAFT_PUBLIC_BASE_URL=http://10.0.0.5:38429

# ----------------------------------------------------------------------------
# Testing / mock (optional; leave unset in normal use)
# ----------------------------------------------------------------------------
# Set to "true" to use in-memory mock clients instead of hitting the real APIs.
# PCRAFT_MOCK_JNPM=true
# PCRAFT_MOCK_LARK=true
